    @ExecSpace("ServerOnly")
    method void OnEndPlay()
        -- 엘퀴네스 타이머 누수 방지
        if self.elquinesTimerId ~= 0 then
            _TimerService:ClearTimer(self.elquinesTimerId)
            self.elquinesTimerId = 0
        end
    end
end
