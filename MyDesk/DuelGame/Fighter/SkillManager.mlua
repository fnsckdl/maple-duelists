    end

    @ExecSpace("Multicast")
    method void VFX_IL_Blizzard(integer dir)
        -- 블리자드 광역 이펙트 (다중 파티클)
        local pos  = self.Entity.TransformComponent.WorldPosition
        local cs   = self.Entity.TransformComponent.Scale
        local sc   = math.abs(cs.x)
        local opts = { SortingLayer = "Character", OrderInLayer = 8, Color = Color(1, 1, 1, 0.9) }
        if self.vfxRUID_IL_Blizzard ~= "" then
            _EffectService:PlayEffect(self.vfxRUID_IL_Blizzard, self.Entity, pos, 0, Vector3(3*sc, 3*sc, 1), false, opts)
        end
        if self.sfxRUID_IL_Ice ~= "" then _SoundService:PlaySound(self.sfxRUID_IL_Ice, 0.5) end
    end

