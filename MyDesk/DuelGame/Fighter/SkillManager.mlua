    method void VFX_RushHit(integer dir)
        self:PlayVFX(self.vfxRUID_RushHit, self.sfxRUID_RushHit, dir, 1.0, 0.3, 1.2, 1.0, 10, Color(1,1,1,1))
    end

    @ExecSpace("Multicast")
    method void VFX_PSCharge(integer dir)
