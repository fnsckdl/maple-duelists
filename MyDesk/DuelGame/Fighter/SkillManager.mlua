    method void VFX_PSHit(integer dir)
        self:PlayVFX(self.vfxRUID_PSHit, self.sfxRUID_PSHit, dir, 0.8, 0.2, 1.3, 1.2, 10, Color(1, 1, 1, 1))
    end

