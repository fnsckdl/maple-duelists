    end

    @ExecSpace("Multicast")
    method void VFX_BM_PiercingShot(integer dir)
        self:PlayVFX(self.vfxRUID_BM_PiercingShot, self.sfxRUID_BM_PiercingShot, dir, 2.5, 0.3, 1.5, 0.6, 10, Color(1, 1, 1, 1))
    end

    @ExecSpace("Multicast")
    method void VFX_BM_IronArrow(integer dir)
        self:PlayVFX(self.vfxRUID_BM_IronArrow, self.sfxRUID_BM_IronArrow, dir, 2.2, 0.3, 1.3, 0.6, 10, Color(1, 1, 1, 1))
    end

    @ExecSpace("Multicast")
    method void VFX_BM_MortalBlow(integer dir)
        self:PlayVFX(self.vfxRUID_BM_MortalBlow, self.sfxRUID_BM_MortalBlow, dir, 2.2, 0.3, 1.2, 0.6, 10, Color(1, 1, 1, 1))
    end

    @ExecSpace("Multicast")
    method void VFX_BM_SniperFire(integer dir)
        local base = self.Entity.TransformComponent.WorldPosition
        local cs   = self.Entity.TransformComponent.Scale
        local sc   = math.abs(cs.x)
        local opts = { SortingLayer = "Character", FlipX = (dir < 0) }
        -- 1) 화살 투사체 (플레이어 옆에서 발사)
        if self.vfxRUID_BM_SniperBall ~= "" then
            opts.OrderInLayer = 15
            opts.Color = Color(1, 1, 1, 1)
            _EffectService:PlayEffect(self.vfxRUID_BM_SniperBall, self.Entity,
                Vector3(base.x + dir * 0.3 * sc, base.y + 0.3, base.z),
                0, Vector3(0.8*sc, 0.4*sc, 1), false, opts)
        end
        -- 2) 스킬 발동 이펙트 (전방 중거리)
        if self.vfxRUID_BM_SniperEffect ~= "" then
            opts.OrderInLayer = 18
            opts.Color = Color(1, 1, 1, 1)
            _EffectService:PlayEffect(self.vfxRUID_BM_SniperEffect, self.Entity,
                Vector3(base.x + dir * 2.0 * sc, base.y + 0.3, base.z),
                0, Vector3(1.2*sc, 0.8*sc, 1), false, opts)
        end
        -- 3) 타격 이펙트 (전방 원거리)
        if self.vfxRUID_BM_SniperHit ~= "" then
            opts.OrderInLayer = 16
            opts.Color = Color(1, 1, 1, 1)
            _EffectService:PlayEffect(self.vfxRUID_BM_SniperHit, self.Entity,
                Vector3(base.x + dir * 3.5 * sc, base.y + 0.3, base.z),
                0, Vector3(1.0*sc, 0.8*sc, 1), false, opts)
        end
        if self.sfxRUID_BM_Sniping  ~= "" then _SoundService:PlaySound(self.sfxRUID_BM_Sniping, 0.5) end
        if self.sfxRUID_BM_SniperHit ~= "" then _SoundService:PlaySound(self.sfxRUID_BM_SniperHit, 0.5) end
    end

    @ExecSpace("Multicast")
    method void VFX_BM_PiercingStorm(integer dir)
        -- ── 피어싱 폭풍: 플레이어 위치에서 발생, 전방으로 뻗어나감 ──
        self:PlayVFX(self.vfxRUID_BM_Piercing, self.sfxRUID_BM_Piercing, dir, 0.0, 0.3, 2.0, 1.2, 12, Color(1, 1, 1, 1))
    end

    @ExecSpace("Multicast")
    method void VFX_BM_BackStep(integer dir)
        -- ── 후방이동: 뒤 방향 대시 이펙트 ──────────────────────────
        self:PlayVFX(self.vfxRUID_BM_BackStep, self.sfxRUID_BM_BackStep, -dir, 0.5, 0.2, 1.2, 1.0, 8, Color(1, 1, 1, 1))
    end

    @ExecSpace("Multicast")
    method void VFX_BM_ArrowLaunch(integer dir, Entity arrowEnt)
        -- ── 화살 발사: 화살 엔티티에 부착 (커스텀 — Entity 파라미터) ──
        -- 화살 스프라이트 자체가 보이도록 고쳐서, 겹쳐 보이던 부착 이펙트(ArrowBall)는 제거했다.
        if self.sfxRUID_BM_BasicSwing ~= "" then _SoundService:PlaySound(self.sfxRUID_BM_BasicSwing, 0.5) end
    end

    @ExecSpace("Multicast")
    method void VFX_BM_BoltSweep(integer dir)
        -- ── 볼트 스위프: 부채꼴 3점 (커스텀 — 다중 위치) ──────────
        local pos  = self.Entity.TransformComponent.WorldPosition
        local cs   = self.Entity.TransformComponent.Scale
        local sc   = math.abs(cs.x)
        local opts = { SortingLayer = "Character", OrderInLayer = 10, FlipX = (dir < 0), Color = Color(1, 1, 1, 1) }
        -- 스윕 전체 이펙트 (origin 1회)
        if self.vfxRUID_BM_BoltSweep ~= "" then
            _EffectService:PlayEffect(self.vfxRUID_BM_BoltSweep, self.Entity, Vector3(pos.x + dir*1.2*sc, pos.y + 0.8, pos.z), 0, Vector3(0.9*sc, 0.9*sc, 1), false, opts)
        end
        -- 각 타격점 hit 이펙트
        local pts  = {
            Vector3(pos.x + dir*1.2*sc, pos.y + 1.5, pos.z),
            Vector3(pos.x + dir*1.8*sc, pos.y + 0.8, pos.z),
            Vector3(pos.x + dir*2.0*sc, pos.y + 0.2, pos.z),
        }
        for _, p in ipairs(pts) do
            if self.vfxRUID_BM_BoltSweepHit ~= "" then
                _EffectService:PlayEffect(self.vfxRUID_BM_BoltSweepHit, self.Entity, p, 0, Vector3(0.8*sc, 0.4*sc, 1), false, opts)
            else
                _ParticleService:PlayBasicParticle(BasicParticleType.SparkLoop, self.Entity, p, 0, Vector3(1.2*sc, 0.5*sc, 1), false, opts)
            end
        end
        if self.sfxRUID_BM_BoltSweep ~= "" then _SoundService:PlaySound(self.sfxRUID_BM_BoltSweep, 0.5) end
    end

    @ExecSpace("Multicast")
    method void VFX_BM_SniperAim(integer dir)
        -- ── 스나이핑 조준선: 회전 90도 레이저 (커스텀) ─────────────
        local pos  = self.Entity.TransformComponent.WorldPosition
        local cs   = self.Entity.TransformComponent.Scale
        local sc   = math.abs(cs.x)
        local opts = { SortingLayer = "Character", OrderInLayer = 15, Color = Color(1, 1, 1, 0.8) }
        _ParticleService:PlayBasicParticle(BasicParticleType.LightningStrikeSharp, self.Entity,
            Vector3(pos.x + dir * 4*sc, pos.y + 0.3, pos.z), 90, Vector3(0.2, 6*sc, 1), false, opts)
    end

    @ExecSpace("Multicast")
    method void VFX_BM_SplitArrow(integer dir)
        -- ── 스플릿 애로우: 분열 + 3방향 산탄 (커스텀) ──────────────
        local pos   = self.Entity.TransformComponent.WorldPosition
        local cs    = self.Entity.TransformComponent.Scale
        local sc    = math.abs(cs.x)
        local split = Vector3(pos.x + dir*2.5*sc, pos.y + 0.3, pos.z)
        local opts  = { SortingLayer = "Character", OrderInLayer = 12, Color = Color(1, 1, 1, 1) }
        if self.vfxRUID_BM_SplitArrow ~= "" then
            _EffectService:PlayEffect(self.vfxRUID_BM_SplitArrow, self.Entity, split, 0, Vector3(0.75*sc,0.75*sc,1), false, opts)
        else
            _ParticleService:PlayBasicParticle(BasicParticleType.SparkRadialExplosion, self.Entity, split, 0, Vector3(0.75*sc,0.75*sc,1), false, opts)
            _ParticleService:PlayBasicParticle(BasicParticleType.SparkLoop, self.Entity, Vector3(split.x, split.y+0.5, split.z), 0, Vector3(0.4*sc,0.2,1), false, opts)
            _ParticleService:PlayBasicParticle(BasicParticleType.SparkLoop, self.Entity, Vector3(split.x+dir*0.3*sc, split.y-0.3, split.z), 0, Vector3(0.4*sc,0.2,1), false, opts)
        end
        if self.sfxRUID_BM_SplitArrow ~= "" then _SoundService:PlaySound(self.sfxRUID_BM_SplitArrow, 0.5) end
    end

    @ExecSpace("Multicast")
    method void VFX_BM_FinalAimBuff()
        -- ── 파이널 에임 버프: 루프 부착 (커스텀) ───────────────────
        if self.finalAimSerial > 0 then
            _EffectService:RemoveEffect(self.finalAimSerial)
            self.finalAimSerial = -1
        end
        local aOpts = { SortingLayer = "Character", OrderInLayer = 3, Color = Color(1, 1, 1, 0.85) }
        self.finalAimSerial = _EffectService:PlayEffectAttached(self.vfxRUID_BM_FinalAim, self.Entity, Vector3(0,0,0), 0, Vector3(0.5,0.5,1), true, aOpts)
        if self.sfxRUID_BM_FinalAim ~= "" then _SoundService:PlaySound(self.sfxRUID_BM_FinalAim, 0.5) end
        local s = self.finalAimSerial
        _TimerService:SetTimerOnce(function()
            if s > 0 then _EffectService:RemoveEffect(s) end
        end, 10.0)
    end

    @ExecSpace("Multicast")
    method void VFX_FAOrigin(integer dir)
        -- ── 파이널 에임 오리진: 저격 착탄 (커스텀 — 다중 이펙트) ───
        local pos    = self.Entity.TransformComponent.WorldPosition
        local cs     = self.Entity.TransformComponent.Scale
        local sc     = math.abs(cs.x)
        local hitPos = Vector3(pos.x + dir * 6*sc, pos.y + 0.3, pos.z)
        local opts   = { SortingLayer = "Character", OrderInLayer = 20, FlipX = (dir < 0), Color = Color(1, 1, 1, 1) }
        if self.vfxRUID_FAOriginHit ~= "" then
            _EffectService:PlayEffect(self.vfxRUID_FAOriginHit, self.Entity, hitPos, 0, Vector3(1.5*sc, 0.5*sc, 1), false, opts)
        end
        local cOpts = { SortingLayer = "Character", OrderInLayer = 18, Color = Color(1, 1, 1, 1) }
        _ParticleService:PlayBasicParticle(BasicParticleType.LightningBlast,           self.Entity, pos,    0, Vector3(2*sc, 2*sc, 1),   false, cOpts)
        _ParticleService:PlayBasicParticle(BasicParticleType.LightningStrikeSharpTall, self.Entity, hitPos, 0, Vector3(0.3*sc, 5*sc, 1), false, cOpts)
        if self.sfxRUID_FAOrigin ~= "" then _SoundService:PlaySound(self.sfxRUID_FAOrigin, 0.5) end
    end

    -- ══════════════════════════════════════════════════════════
    --  섀도어 스킬 구현
    -- ══════════════════════════════════════════════════════════

    @ExecSpace("ServerOnly")
    method void BA_Shadower()
        local dir = self:LookDir()
        local atkComp = self:GetAtk()
        for i = 1, 2 do
            if atkComp ~= nil then
                ---@type AttackComponent
                local atk = atkComp
                atk:Attack(Vector2(0.7, 0.8), Vector2(dir * 0.4, 0.2), "basic")
            end
            if i < 2 then wait(0.08) end
        end
        self:SpawnShuriken(dir)
        log("[SkillMgr] 섀도어 기본공격 2연타 + 표창")
    end

    @ExecSpace("ServerOnly")
    method void SpawnShuriken(integer dir)
        -- 표창 투사체 스폰 (2연타 직후 발사)
        local pos = self.Entity.TransformComponent.Position
        local map = self.Entity.CurrentMap
        if not isvalid(map) then return end
        if self._T.shurikenCount == nil then self._T.shurikenCount = 0 end
        self._T.shurikenCount = self._T.shurikenCount + 1
        local spawnPos = Vector3(pos.x + dir * 0.4, pos.y + 0.25, pos.z)
        local shuriken = _SpawnService:SpawnByModelId(
            "tfshuriken",
            "tf_shuriken_" .. tostring(self._T.shurikenCount),
            spawnPos,
            map
        )
        if isvalid(shuriken) then
            shuriken:AddComponent("script.TFShurikenProjectile")
            local proj = shuriken:GetComponent("script.TFShurikenProjectile")
            if proj ~= nil then
                ---@type TFShurikenProjectile
                local p = proj
                p.hitRUID = self.vfxRUID_TF_SavageBlow
                p:Init(dir, self.Entity)
            end
            self:VFX_TF_ShurikenLaunch(dir, shuriken)
        end
        log("[SkillMgr] 표창 발사 dir=" .. tostring(dir))
    end

    @ExecSpace("Multicast")
    method void VFX_TF_ShurikenLaunch(integer dir, Entity shurikenEnt)
        -- 표창 비행 VFX: 표창 스프라이트 자체가 보이므로 겹쳐 보이던 부착 이펙트는 제거했다.
    end

    @ExecSpace("ServerOnly")
    method void Shadower_SkillDispatch(integer slot)
        -- X=1(스틸)  C=2(다크사이트)  Z=3(새비지블로우)  F=4(헤이스트)
        -- Q=5(어썰터)  E=6(메소익스플로전)
        -- 1=7(부메랑스텝)  2=8(연막탄)  3=9(절개)  4=10(멸귀참영진)
        -- V=11(소닉블로우)
        if     slot == 1  then self:SetSkillCD(1,  3.0);  self:TF_Stele()
        elseif slot == 2  then self:SetSkillCD(2,  8.0);  self:TF_DarkSight()
        elseif slot == 3  then self:SetSkillCD(3,  5.0);  self:TF_SavageBlow()
        elseif slot == 4  then self:SetSkillCD(4, 12.0);  self:TF_Heist()
        elseif slot == 5  then self:SetSkillCD(5,  6.0);  self:TF_Assaulter()
        elseif slot == 6  then self:SetSkillCD(6,  6.0);  self:TF_MesoExplosion()
        elseif slot == 7  then self:SetSkillCD(7,  5.0);  self:TF_BoomerangStep()
        elseif slot == 8  then self:SetSkillCD(8, 15.0);  self:TF_SmokeScreen()
        elseif slot == 9  then self:SetSkillCD(9, 12.0);  self:TF_Jeolle()
        elseif slot == 10 then self:SetSkillCD(10,20.0);  self:TF_ShadowWorldSword()
        elseif slot == 11 then self:SetSkillCD(11,30.0);  self:TF_SonicBlow()
        end
    end

    @ExecSpace("ServerOnly")
    method void TF_SavageBlow()
        -- [Z] 새비지 블로우: 초근접 6연타 (CD 5.0s)
        local dir = self:LookDir()
        local atkComp = self:GetAtk()
        for i = 1, 6 do
            if atkComp ~= nil then
                ---@type AttackComponent
                local atk = atkComp
                atk:Attack(Vector2(0.6, 0.7), Vector2(dir * 0.3, 0.1), "savage_blow")
            end
            self:VFX_TF_BasicHit(dir)
            if i < 6 then wait(0.06) end
        end
        log("[SkillMgr] 새비지 블로우 6연타")
    end

    @ExecSpace("ServerOnly")
    method void TF_DarkSight()
        -- [C] 다크사이트: 1.5초간 투사체·마법 계열 면역 (CD 8.0s)
        local fc = self:GetFC()
        if fc ~= nil then
            ---@type FighterComponent
            local f = fc
            f:ActivateDarkSight(1.5)
        end
        self:VFX_TF_DarkSight()
        log("[SkillMgr] 다크사이트 (1.5초 투사체 면역)")
    end

    @ExecSpace("ServerOnly")
    method void TF_Heist()
        -- [F] 헤이스트: 5초간 이동속도 1.5배 버프 (CD 12.0s)
        local fc = self:GetFC()
        if fc ~= nil then
            ---@type FighterComponent
            local f = fc
            f:ActivateHeist(5.0)
        end
        self:VFX_TF_Heist()
        log("[SkillMgr] 헤이스트 (이속 1.5배 5초)")
    end

    @ExecSpace("ServerOnly")
    method void TF_Assaulter()
        -- [Q] 어썰터: 적 후방 순간이동 후 관통 타격 (CD 6.0s)
        local dir = self:LookDir()
        -- 적 앞 0.8유닛으로 이동
        local oppEnt = self:GetOpponentEntity()
        if isvalid(oppEnt) then
            local oppPos = oppEnt.TransformComponent.WorldPosition
            local arrivalX = oppPos.x - dir * 0.8
            local myPos = self.Entity.TransformComponent.WorldPosition
            _TeleportService:TeleportToMapPosition(self.Entity, Vector3(arrivalX, myPos.y, myPos.z), "")
        end
        wait(0.08)
        local atkComp = self:GetAtk()
        if atkComp ~= nil then
            ---@type AttackComponent
            local atk = atkComp
            atk:Attack(Vector2(1.2, 1.0), Vector2(dir * 0.6, 0.2), "assaulter")
        end
        self:VFX_TF_Assaulter(dir)
        log("[SkillMgr] 어썰터 (순간이동 기습)")
    end

    @ExecSpace("ServerOnly")
    method void TF_BoomerangStep()
        -- [1] 부메랑 스텝: 전방 원형 투척 + 귀환 넉백 (CD 5.0s)
        local dir = self:LookDir()
        local atkComp = self:GetAtk()
        if atkComp ~= nil then
            ---@type AttackComponent
            local atk = atkComp
            -- 전방 투척
            atk:Attack(Vector2(3.5, 0.9), Vector2(dir * 1.8, 0.2), "boomerang")
            wait(0.2)
            -- 귀환 (반대 방향)
            atk:Attack(Vector2(3.5, 0.9), Vector2(-dir * 1.8, 0.2), "boomerang_return")
        end
        log("[SkillMgr] 부메랑 스텝 (왕복 넉백)")
    end

    @ExecSpace("ServerOnly")
    method void TF_Stele()
        -- [X] 스틸: 전방 돌진 베기 (CD 3.0s)
        local dir = self:LookDir()
        local body = self.Entity.RigidbodyComponent
        if isvalid(body) then body:AddForce(Vector2(dir * 10, 0)) end
        wait(0.12)
        local atkComp = self:GetAtk()
        if atkComp ~= nil then
            ---@type AttackComponent
            local atk = atkComp
            atk:Attack(Vector2(1.4, 1.0), Vector2(dir * 0.7, 0.2), "stele")
        end
        log("[SkillMgr] 스틸 (돌진 베기)")
    end

    @ExecSpace("ServerOnly")
    method void TF_MesoExplosion()
        -- [E] 메소 익스플로전: 동전 폭발 + 에어본 (CD 6.0s)
        local dir = self:LookDir()
        local atkComp = self:GetAtk()
        if atkComp ~= nil then
            ---@type AttackComponent
            local atk = atkComp
            atk:Attack(Vector2(2.2, 1.8), Vector2(dir * 0.3, 0.5), "meso_explosion")
        end
        self:VFX_TF_MesoExplosion(dir)
        log("[SkillMgr] 메소 익스플로전 (폭발+에어본)")
    end

    @ExecSpace("ServerOnly")
    method void TF_SmokeScreen()
        -- [2] 연막탄: 1초간 무적 + 반투명 은신 (CD 15.0s)
        local fc = self:GetFC()
        if fc ~= nil then
            ---@type FighterComponent
            local f = fc
            f:ActivateInvincible(1.0)
        end
        self:VFX_TF_SmokeScreen()
        log("[SkillMgr] 연막탄 (1초 무적 은신)")
    end

    @ExecSpace("ServerOnly")
    method void TF_Jeolle()
        -- [3] 절개: 적 후방으로 순간이동 후 2연격 기습 (CD 12.0s)
        local dir = self:LookDir()
        local oppEnt = self:GetOpponentEntity()
        if isvalid(oppEnt) then
            local oppPos = oppEnt.TransformComponent.WorldPosition
            local myPos  = self.Entity.TransformComponent.WorldPosition
            _TeleportService:TeleportToMapPosition(self.Entity, Vector3(oppPos.x + dir * 1.0, myPos.y, myPos.z), "")
        end
        wait(0.05)
        local atkComp = self:GetAtk()
        if atkComp ~= nil then
            ---@type AttackComponent
            local atk = atkComp
            atk:Attack(Vector2(0.9, 0.9), Vector2(dir * 0.4, 0.2), "jeolle")
            self:VFX_TF_Jeolle(dir)
            wait(0.1)
            atk:Attack(Vector2(1.5, 1.2), Vector2(dir * 0.7, 0.3), "jeolle_finish")
            self:VFX_TF_Jeolle(dir)
        end
        log("[SkillMgr] 절개 (뒤잡기 2연격)")
    end

    @ExecSpace("ServerOnly")
    method void TF_ShadowWorldSword()
        -- [4] 멸귀참영진: 전 화면 6연 고속 난무 (CD 20.0s)
        local dir = self:LookDir()
        local atkComp = self:GetAtk()
        self:VFX_TF_ShadowWorld(dir)
        for i = 1, 6 do
            if atkComp ~= nil then
                ---@type AttackComponent
                local atk = atkComp
                local ox = (i % 2 == 0) and (dir * 1.5) or (dir * 0.8)
                local oy = (i % 3 == 0) and 0.8 or (i % 3 == 1 and 0.0 or -0.4)
                atk:Attack(Vector2(8.0, 5.0), Vector2(ox, oy), "shadow_world")
            end
            if i < 6 then wait(0.12) end
        end
        log("[SkillMgr] 멸귀참영진 (전 화면 6연 난무)")
    end

    @ExecSpace("ServerOnly")
    method void TF_SonicBlow()
        -- [V] 소닉 블로우: 적 앞 순간이동 + 15연타 오리진 필살기 (CD 30.0s)
        local dir = self:LookDir()
        local oppEnt = self:GetOpponentEntity()
        if isvalid(oppEnt) then
            local oppPos = oppEnt.TransformComponent.WorldPosition
            local myPos  = self.Entity.TransformComponent.WorldPosition
            -- 경직: 시전 첫 프레임에 전방 적 0.3s 강제 경직
            local oppFC = oppEnt:GetComponent("script.FighterComponent")
            if oppFC ~= nil then
                ---@type FighterComponent
                local of = oppFC
                of:ApplyStun(0.3)
            end
            _TeleportService:TeleportToMapPosition(self.Entity, Vector3(oppPos.x - dir * 0.7, myPos.y, myPos.z), "")
        end
        wait(0.05)
        self:VFX_TF_SonicBlow(dir)
        local atkComp = self:GetAtk()
        for i = 1, 15 do
            if atkComp ~= nil then
                ---@type AttackComponent
                local atk = atkComp
                local power = (i == 15) and 3.0 or 1.0
                atk:Attack(Vector2(0.8 * power, 0.8 * power), Vector2(dir * 0.4, 0.1), "sonic_blow")
            end
            if i < 15 then wait(0.04) end
        end
        log("[SkillMgr] 소닉 블로우 15연타!")
    end

    @ExecSpace("ServerOnly")
    method void UseFlashJump()
        -- [Alt×2] 플래시 점프: 전방+상방 공중 대시 (CD 5.0s, ExecuteFlashJump에서 진입)
        local dir = self:LookDir()
        local body = self.Entity.RigidbodyComponent
        if isvalid(body) then
            body:AddForce(Vector2(dir * 3, 0.8))
        end
        self:VFX_TF_DoubleJump(dir)
        log("[SkillMgr] 플래시 점프 dir=" .. tostring(dir))
    end

    -- ══════════════════════════════════════════════════════════
    --  썬콜 스킬 구현
    -- ══════════════════════════════════════════════════════════

    @ExecSpace("ServerOnly")
    method void BA_Mage()
        local dir = self:LookDir()
        local atkComp = self:GetAtk()
        for i = 1, 2 do
            if atkComp ~= nil then
                ---@type AttackComponent
                local atk = atkComp
                atk:Attack(Vector2(2.8, 0.7), Vector2(dir * 1.4, 0.2), "basic")
            end
            self:VFX_IL_BasicBolt(dir)
            if i < 2 then wait(0.08) end
        end
        log("[SkillMgr] 매직 클로 2연격")
    end

    @ExecSpace("ServerOnly")
    method void Mage_SkillDispatch(integer slot)
        -- X=1(아이스 스트라이크)  C=2(체인 라이트닝)  Z=3(썬더 볼트)  F=4(블리자드)
        -- Q=5(글레이셜 체인, CD 6s)  E=6(엘퀴네스, CD 15s)  1=7(인피니티, CD 25s)
        -- 2=8(콜드 빔, CD 5s)  3=9(매직 가드, CD 15s)  4=10(오버로드 마나, CD 20s)
        -- V=11(프로즌 라이트닝, CD 50s)  Shift=텔레포트
        if     slot == 1  then                             self:IL_IceStrike()
        elseif slot == 2  then self:SetSkillCD(2,  3.0);  self:IL_ChainLightning()
        elseif slot == 3  then                             self:IL_ThunderBolt()
        elseif slot == 4  then self:SetSkillCD(4, 20.0);  self:IL_Blizzard()
        elseif slot == 5  then self:SetSkillCD(5,  6.0);  self:IL_GlacialChain()
        elseif slot == 6  then self:SetSkillCD(6, 15.0);  self:IL_Elquines()
        elseif slot == 7  then self:SetSkillCD(7, 25.0);  self:IL_Infinity()
        elseif slot == 8  then self:SetSkillCD(8,  5.0);  self:IL_ColdBeam()
        elseif slot == 9  then self:SetSkillCD(9, 15.0);  self:IL_MagicGuard()
        elseif slot == 10 then self:SetSkillCD(10,20.0);  self:IL_OverloadMana()
        elseif slot == 11 then self:SetSkillCD(11,50.0);  self:IL_FrozenLightning()
        end
    end

    @ExecSpace("ServerOnly")
    method void IL_ThunderBolt()
        -- [Z] 썬더 볼트: 자신 중심 원형 방전 (CD없음)
        local dir = self:LookDir()
        local atkComp = self:GetAtk()
        if atkComp ~= nil then
            ---@type AttackComponent
            local atk = atkComp
            -- 좌우 양방향 동시 히트박스
            atk:Attack(Vector2(2.5, 2.0), Vector2(0, 0), "thunder_bolt")
        end
        self:VFX_IL_LightningBolt(dir)
        log("[SkillMgr] 썬더 볼트 (원형 방전)")
    end

    @ExecSpace("ServerOnly")
    method void IL_IceStrike()
        -- [X] 아이스 스트라이크: 전방 짧은 범위 (CD없음)
        local dir = self:LookDir()
        local atkComp = self:GetAtk()
        if atkComp ~= nil then
            ---@type AttackComponent
            local atk = atkComp
            atk:Attack(Vector2(2.2, 1.6), Vector2(dir * 0.8, 0.3), "ice_strike")
        end
        self:VFX_IL_IceStrike(dir)
        log("[SkillMgr] 아이스 스트라이크")
    end

    @ExecSpace("ServerOnly")
    method void IL_ChainLightning()
        -- [C] 체인 라이트닝: 유도 추격 3연타 (CD 3.0s)
        local dir = self:LookDir()
        local atkComp = self:GetAtk()
        for i = 1, 3 do
            if atkComp ~= nil then
                ---@type AttackComponent
                local atk = atkComp
                atk:Attack(Vector2(3.5 + i * 0.3, 0.9), Vector2(dir * (1.5 + i * 0.3), 0.2), "chain_lightning")
            end
            self:VFX_IL_ChainHit(dir, i)
            if i < 3 then wait(0.1) end
        end
        log("[SkillMgr] 체인 라이트닝 추격 3타")
    end

    @ExecSpace("ServerOnly")
    method void IL_GlacialChain()
        -- [Q] 글레이셜 체인: 얼음 사슬로 적을 내 앞으로 끌어당김 (CD 6.0s)
        local dir = self:LookDir()
        local atkComp = self:GetAtk()
        if atkComp ~= nil then
            ---@type AttackComponent
            local atk = atkComp
            atk:Attack(Vector2(4.5, 0.8), Vector2(dir * 2.0, 0.2), "glacial_chain")
        end
        -- 적을 내 앞으로 끌어당김 (속도 초기화 후 시전자 발판 Y 기준 이동)
        local oppEnt = self:GetOpponentEntity()
        if isvalid(oppEnt) then
            local oppBody = oppEnt.RigidbodyComponent
            if isvalid(oppBody) then
                oppBody:SetForce(Vector2(0, 0))
            end
            local myPos = self.Entity.TransformComponent.WorldPosition
            local pullX = myPos.x + dir * 1.5
            _TeleportService:TeleportToMapPosition(oppEnt, Vector3(pullX, myPos.y, myPos.z), "")
        end
        log("[SkillMgr] 글레이셜 체인 (적 끌어당김)")
    end

    @ExecSpace("ServerOnly")
    method void IL_Elquines()
        -- [E] 엘퀴네스: 얼음 정령 소환 — 8초간 범위 내 적 자동 얼음 화살 (CD 15.0s)
        local fc = self:GetFC()
        if fc ~= nil then
            ---@type FighterComponent
            local f = fc
            f:ActivateElquines(8.0)
        end
        -- 기존 타이머 정리 후 1.5초 주기 자동공격 시작
        if self.elquinesTimerId ~= 0 then
            _TimerService:ClearTimer(self.elquinesTimerId)
            self.elquinesTimerId = 0
        end
        self.elquinesTimerId = _TimerService:SetTimerRepeat(function() self:ElquinesAutoAttack() end, 1.5)
        self:VFX_IL_Elquines()
        _TimerService:SetTimerOnce(function()
            if self.elquinesTimerId ~= 0 then
                _TimerService:ClearTimer(self.elquinesTimerId)
                self.elquinesTimerId = 0
            end
            local fc2 = self:GetFC()
            if fc2 ~= nil then
                ---@type FighterComponent
                local f2 = fc2
                f2.ElquinesActive = false
                f2.ElquinesTimer  = 0
            end
        end, 8.0)
        log("[SkillMgr] 엘퀴네스 소환 (8초 자동공격)")
    end

    @ExecSpace("ServerOnly")
    method void ElquinesAutoAttack()
        -- 엘퀴네스 주기적 자동공격 (1.5초마다 거리 내 적 타격)
        local fc = self:GetFC()
        if fc == nil then return end
        ---@type FighterComponent
        local f = fc
        if not f.ElquinesActive then return end
        local oppEnt = self:GetOpponentEntity()
        if not isvalid(oppEnt) then return end
        local myPos  = self.Entity.TransformComponent.WorldPosition
        local oppPos = oppEnt.TransformComponent.WorldPosition
        local dx = oppPos.x - myPos.x
        local dy = oppPos.y - myPos.y
        if (dx * dx + dy * dy) > 16.0 then return end  -- 4유닛 반경 밖이면 패스
        local dir = (dx >= 0) and 1 or -1
        local atkComp = self:GetAtk()
        if atkComp ~= nil then
            ---@type AttackComponent
            local atk = atkComp
            atk:Attack(Vector2(0.7, 0.6), Vector2(dir * 0.4, 0.2), "elquines_arrow")
        end
        log("[SkillMgr] 엘퀴네스 얼음 화살 발사")
    end

    @ExecSpace("ServerOnly")
    method void IL_Infinity()
        -- [1] 인피니티: 5초간 모든 스킬 쿨타임 절반 단축 (CD 25.0s)
        local fc = self:GetFC()
        if fc ~= nil then
            ---@type FighterComponent
            local f = fc
            f:ActivateInfinity()
        end
        self:VFX_IL_Infinity()
        log("[SkillMgr] 인피니티 (쿨타임 50% 5초)")
    end

    @ExecSpace("ServerOnly")
    method void IL_Blizzard()
        -- [F] 블리자드: 전 화면 궁극기 + 빙결(슬로우 5초) (CD 20.0s)
        local atkComp = self:GetAtk()
        if atkComp ~= nil then
            ---@type AttackComponent
            local atk = atkComp
            atk:Attack(Vector2(12.8, 4.0), Vector2(0, 0.5), "blizzard")
        end
        local oppEnt = self:GetOpponentEntity()
        if isvalid(oppEnt) then
            local oppFC = oppEnt:GetComponent("script.FighterComponent")
            if oppFC ~= nil then
                ---@type FighterComponent
                local of = oppFC
                of:ApplySlow(5.0)
            end
        end
        local dir = self:LookDir()
        self:VFX_IL_Blizzard(dir)
        log("[SkillMgr] 블리자드 (전 화면 빙결 궁극기)")
    end

    @ExecSpace("ServerOnly")
    method void IL_ColdBeam()
        -- [2] 콜드 빔: 전방 원거리 얼음 투사체 + 슬로우 2초 (CD 5.0s)
        local dir = self:LookDir()
        local atkComp = self:GetAtk()
        if atkComp ~= nil then
            ---@type AttackComponent
            local atk = atkComp
            atk:Attack(Vector2(5.0, 0.8), Vector2(dir * 4.0, 0.1), "cold_beam")
        end
        local oppEnt = self:GetOpponentEntity()
        if isvalid(oppEnt) then
            local oppFC = oppEnt:GetComponent("script.FighterComponent")
            if oppFC ~= nil then
                ---@type FighterComponent
                local of = oppFC
                of:ApplySlow(2.0)
            end
        end
        self:VFX_IL_ColdBeam(dir)
        log("[SkillMgr] 콜드 빔 (슬로우 2초)")
    end

    @ExecSpace("ServerOnly")
    method void IL_MagicGuard()
        -- [3] 매직 가드: 5초간 피해 40% 감소 (CD 15.0s)
        local fc = self:GetFC()
        if fc ~= nil then
            ---@type FighterComponent
            local f = fc
            f:ActivateMagicGuard(5.0)
        end
        self:VFX_IL_MagicGuard()
        log("[SkillMgr] 매직 가드 (5초 피해 40% 감소)")
    end

    @ExecSpace("ServerOnly")
    method void IL_OverloadMana()
        -- [4] 오버로드 마나: HP 150 소모 → 5초간 공격력 1.5배 (CD 20.0s)
        local fc = self:GetFC()
        if fc ~= nil then
            ---@type FighterComponent
            local f = fc
            if f.HP <= 1 then
                log("[SkillMgr] 오버로드 마나: HP 부족으로 발동 불가")
                return
            end
            f:ActivateOverloadMana(150, 5.0)
        end
        self:VFX_IL_OverloadMana()
        log("[SkillMgr] 오버로드 마나 (HP 150 소모, 5초간 1.5배)")
    end

    @ExecSpace("ServerOnly")
    method void IL_FrozenLightning()
        -- [V] 프로즌 라이트닝: 전 화면 얼음+번개 폭풍 + 3초 기절 (CD 50.0s)
        local dir = self:LookDir()
        local atkComp = self:GetAtk()
        if atkComp ~= nil then
            ---@type AttackComponent
            local atk = atkComp
            -- 경직: 시전 첫 프레임에 전방 적 0.3s 강제 경직
        local oppEnt = self:GetOpponentEntity()
        if isvalid(oppEnt) then
            local oppFC = oppEnt:GetComponent("script.FighterComponent")
            if oppFC ~= nil then
                ---@type FighterComponent
                local of = oppFC
                of:ApplyStun(0.3)
            end
        end
        atk:Attack(Vector2(12.8, 8.0), Vector2(0, 0), "frozen_lightning")
        end
        self:VFX_IL_FrozenLightning(dir)
        log("[SkillMgr] 프로즌 라이트닝 (전 화면 빙결 기절 3초)")
    end

    @ExecSpace("ServerOnly")
    method void UseTeleport(integer dirH, integer dirV)
        -- [Shift+방향] 텔레포트: 입력 방향으로 순간이동 (CD 2.0s, ExecuteTeleportSkill에서 진입)
        -- dirH: -1=왼쪽/0=중립(바라보는 방향)/1=오른쪽  dirV: -1=아래/0=중립/1=위
        local pos    = self.Entity.TransformComponent.WorldPosition
        local faceDir = self:LookDir()
        local moveH   = (dirH ~= 0) and dirH or faceDir
        local dx = moveH * 4.0
        local dy = 0.0
        if dirV == 1 then
            dy = 3.0
        elseif dirV == -1 then
            dy = -2.0
        end
        local newPos = Vector3(pos.x + dx, pos.y + dy, pos.z)
        _TeleportService:TeleportToMapPosition(self.Entity, newPos, "")
        log("[SkillMgr] 텔레포트 dx=" .. dx .. " dy=" .. dy)
    end

