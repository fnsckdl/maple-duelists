    method void VFX_BraveSlash(integer dir, integer hit)
        -- hit(1~3): 전방 오프셋 점진 확장
        self:PlayVFX(self.vfxRUID_BraveSlash, self.sfxRUID_BraveSlash, dir, 0.5 + hit * 0.2, 0.3, 1.1, 1.0, 10, Color(1, 1, 1, 1))
